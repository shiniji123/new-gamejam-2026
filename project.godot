; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="New Gamejam 2026"
run/main_scene="uid://dpucpeempaxyb"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

InteractionManager="*res://interaction/interaction_manager.tscn"
AudioManager="*res://scripts/autoloads/audio_manager.gd"
Autoload="*res://scripts/autoloads/autoload.gd"
SceneManager="*res://scripts/autoloads/scene_manager.gd"
RunManager="*res://scripts/autoloads/run_manager.gd"
StatCalculator="*res://scripts/system/stat_calculator.gd"
DialogueManager="*uid://c3rodes2l3gxb"
Dialogic="*uid://ds2q0uclmolvu"

[dialogic]

directories/dch_directory={
"player": "res://timeline/Portrait/player.dch"
}
directories/dtl_directory={
"Scene_01": "res://timeline/Scene_01.dtl",
"scene_01": "res://timeline/scene_01.dtl"
}
layout/style_directory={
"": "res://addons/dialogic/dialog.tres",
"dialog": "res://addons/dialogic/dialog.tres"
}
glossary/default_case_sensitive=true
layout/style_list=["res://addons/dialogic/dialog.tres"]
layout/default_style="res://addons/dialogic/dialog.tres"
variables={
"stage": 0
}

[dialogue_manager]

runtime/balloon_path="uid://b4rmkd0e5kdjc"

[display]

window/size/mode=3

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg", "res://addons/dialogue_manager/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "teal",
"res://assets/": "purple",
"res://interaction/": "orange",
"res://scenes/": "red",
"res://scripts/": "yellow"
}

