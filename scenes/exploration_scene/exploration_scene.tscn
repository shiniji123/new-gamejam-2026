[node name="NotepadArea2" parent="." unique_id=1109612314 instance=ExtResource("3_4dtv0")]
position = Vector2(1018, 362)
require_interact = true
action_name = "Read"
area_color = Color(1, 0.74, 0.18, 0.3)
active_on_event = "read_notepad_1"
is_notepad = true
notepad_title = "📓 บันทึกการกักกันฉบับที่สอง"
notepad_content = "[b]บันทึกการกักกัน / ระดับเตือนภัยสีส้ม[/b]

หลังการปะทะระลอกแรก สัญญาณผิดปกติไม่ได้ลดลง
มันกำลังรวมตัวกันที่จุดเดิม และเริ่มสร้างแกนพลังงานรูปแบบใหม่

ข้อสันนิษฐาน:
1. การกำจัดหน่วยย่อยทำให้ \"ตัวควบคุม\" ตื่นตัว
2. ถ้าพลังงานสะสมครบ มันจะปล่อยร่างประมวลผลระดับบอสออกมา
3. ผู้ทดสอบภาคสนามต้องเตรียมรับการโจมตีที่หนักกว่าเดิมหลายเท่า

คำแนะนำ:
- เสริมพลังให้พร้อมก่อนเข้ารอบถัดไป
- รักษาระยะขณะบอสเริ่มเปิดเฟส
- อย่าปล่อยให้สนามนิ่งเกินไป เพราะศัตรูจะล้อมเร็วมาก

— ฝ่ายเฝ้าระวังระบบ"
notepad_event_target = "second_notepad"

